<models:BaseRegionUserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Views.PaymentShell"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:controls="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Core.Controls;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Core"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:local="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:models="clr-namespace:HRB.Platform.Client.WPF.Core.Models;assembly=HRB.Platform.Client.WPF.Core"
                              xmlns:prism="http://prismlibrary.com/"
                              xmlns:region="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Core;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Core"
                              d:DesignHeight="450"
                              d:DesignWidth="800"
                              mc:Ignorable="d">
    <Grid>
        <ContentControl Grid.Row="1" prism:RegionManager.RegionName="{x:Static region:PaymentRegionNames.PaymentContentRegion}" />
        <controls:NotificationContainer x:Name="NotificationContainer" Panel.ZIndex="9999" />
        <controls:LoadingOverlayContainer x:Name="LoadingOverlayContainer" Panel.ZIndex="10000" />
    </Grid>
</models:BaseRegionUserControl>
