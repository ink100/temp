<UserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Core.Controls.LoadingOverlayContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Visibility="Collapsed">
    <Grid Background="#80000000">
        <Border Background="White"
                CornerRadius="10"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="300">
            <StackPanel HorizontalAlignment="Center">
                <!-- Loading 动画 -->
                <Viewbox Width="60" Height="60" Margin="0,0,0,20">
                    <Grid>
                        <Ellipse Width="60" Height="60"
                                 Stroke="#0078D7"
                                 StrokeThickness="6"
                                 StrokeDashArray="40,20"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="LoadingRotation" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="LoadingRotation"
                                                           Storyboard.TargetProperty="Angle"
                                                           From="0" To="360" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                </Viewbox>

                <!-- 提示文字 -->
                <TextBlock x:Name="MessageText"
                           Text="正在处理，请稍候..."
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>
                <TextBlock Text="请稍候..."
                           FontSize="14"
                           Foreground="#666666"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
