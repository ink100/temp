<models:BaseRegionUserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Views.HistoryPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:controlExtensions="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Core.ControlExtensions;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Core"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:models="clr-namespace:HRB.Platform.Client.WPF.Core.Models;assembly=HRB.Platform.Client.WPF.Core"
                              xmlns:prism="http://prismlibrary.com/"
                              xmlns:resource="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Resources;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Resources"
                              d:DesignHeight="1080"
                              d:DesignWidth="1920"
                              prism:ViewModelLocator.AutoWireViewModel="True"
                              mc:Ignorable="d">
    <UserControl.Resources>
        <!--  共享列头样式  -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="50" />
        </Style>

        <!--  顶部按钮样式  -->
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  文本列样式  -->
        <Style x:Key="DataGridTextColumnStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!--  金额列样式  -->
        <Style x:Key="DataGridAmountStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!--  状态列样式  -->
        <Style x:Key="StatusColumnStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Grid Grid.Row="0" Background="#0078D7">
            <TextBlock Margin="20,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="24"
                       Foreground="White"
                       Text="历史收款记录" />

            <StackPanel Margin="0,0,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Background="#28A745"
                        Command="{Binding NavigateToMainCommand}"
                        Content="返回"
                        Style="{StaticResource TopButtonStyle}" />
                <Button Margin="12,0,0,0"
                        Background="#17A2B8"
                        Command="{Binding RefreshCommand}"
                        Content="刷新"
                        Style="{StaticResource TopButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  查询条件区域  -->
        <Border Grid.Row="1"
                Margin="20,15"
                Padding="20,15"
                Background="#F5F5F5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="15" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  筛选条件行  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="开始日期：" />
                    <DatePicker Grid.Column="1"
                                VerticalContentAlignment="Center"
                                FontSize="14"
                                SelectedDate="{Binding StartDate}" />

                    <TextBlock Grid.Column="2"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="结束日期：" />
                    <DatePicker Grid.Column="3"
                                VerticalContentAlignment="Center"
                                FontSize="14"
                                SelectedDate="{Binding EndDate}" />

                    <TextBlock Grid.Column="4"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="支付渠道：" />
                    <ComboBox Grid.Column="5"
                              VerticalContentAlignment="Center"
                              FontSize="14"
                              SelectedValue="{Binding SelectedPaymentChannel}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="全部" IsSelected="True" Tag="" />
                        <ComboBoxItem Content="支付宝" Tag="Alipay" />
                        <ComboBoxItem Content="微信" Tag="WeChat" />
                    </ComboBox>

                    <TextBlock Grid.Column="6"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="支付状态：" />
                    <ComboBox Grid.Column="7"
                              VerticalContentAlignment="Center"
                              FontSize="14"
                              SelectedValue="{Binding SelectedPaymentStatus}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="全部" IsSelected="True" Tag="" />
                        <ComboBoxItem Content="扫码中" Tag="Scan" />
                        <ComboBoxItem Content="成功" Tag="Success" />
                        <ComboBoxItem Content="取消" Tag="Cancel" />
                    </ComboBox>

                    <!--  快捷日期按钮组  -->
                    <StackPanel Grid.Column="9" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button Width="60"
                                Height="30"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetTodayCommand}"
                                Content="今日"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="70"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetThisWeekCommand}"
                                Content="这一周"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="70"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetLastWeekCommand}"
                                Content="上一周"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="70"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetThisMonthCommand}"
                                Content="这一月"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="80"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetThisQuarterCommand}"
                                Content="这一季度"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="70"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetThisYearCommand}"
                                Content="这一年"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                        <Button Width="70"
                                Height="30"
                                Margin="8,0,0,0"
                                Background="#E0E0E0"
                                BorderThickness="0"
                                Command="{Binding SetAllCommand}"
                                Content="全部"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="#333333" />
                    </StackPanel>
                </Grid>

                <!--  统计信息行  -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="15,8"
                            Background="White"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Foreground="#666666" Text="总营收：" />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#00A152"
                                       Text="{Binding TotalRevenue, StringFormat='¥{0:N2}'}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="15,0,0,0"
                            Padding="15,8"
                            Background="White"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Foreground="#666666" Text="支付宝：" />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#3F85FF"
                                       Text="{Binding AlipayCount}" />
                            <TextBlock Margin="3,0,0,0"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Text="笔 / " />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#3F85FF"
                                       Text="{Binding AlipayRevenue, StringFormat='¥{0:N2}'}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="15,0,0,0"
                            Padding="15,8"
                            Background="White"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Foreground="#666666" Text="微信：" />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#00897B"
                                       Text="{Binding WeChatCount}" />
                            <TextBlock Margin="3,0,0,0"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Text="笔 / " />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#00897B"
                                       Text="{Binding WeChatRevenue, StringFormat='¥{0:N2}'}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Margin="15,0,0,0"
                            Padding="15,8"
                            Background="White"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Foreground="#666666" Text="成功：" />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#00A152"
                                       Text="{Binding SuccessCount}" />
                            <TextBlock Margin="3,0,0,0"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Text="笔" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Margin="15,0,0,0"
                            Padding="15,8"
                            Background="White"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Foreground="#666666" Text="取消：" />
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#DC3545"
                                       Text="{Binding CancelCount}" />
                            <TextBlock Margin="3,0,0,0"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Text="笔" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!--  数据表格  -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <DataGrid AutoGenerateColumns="False"
                      Background="White"
                      BorderThickness="0"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="False"
                      CanUserSortColumns="False"
                      ColumnHeaderHeight="50"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#E0E0E0"
                      IsReadOnly="True"
                      ItemsSource="{Binding Transactions}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      VerticalGridLinesBrush="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="1.6*"
                                        Binding="{Binding Time}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="时间"
                                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}" />

                    <DataGridTextColumn Width="1.1*"
                                        Binding="{Binding PaymentChannelDisplay}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="支付渠道"
                                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}" />

                    <DataGridTextColumn Width="2.4*"
                                        Binding="{Binding LedgerIdentifierDisplay}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="支付宝流水单号 / 微信wxid"
                                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}" />

                    <DataGridTemplateColumn Width="1.3*" Header="金额">
                        <DataGridTemplateColumn.HeaderStyle>
                            <StaticResource ResourceKey="DataGridColumnHeaderStyle" />
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Text="{Binding AmountDisplay}">
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource DataGridAmountStyle}" TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PaymentChannel}" Value="Alipay">
                                                    <Setter Property="Foreground" Value="#3F85FF" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PaymentChannel}" Value="WeChat">
                                                    <Setter Property="Foreground" Value="#00897B" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="1.5*" Header="状态">
                        <DataGridTemplateColumn.HeaderStyle>
                            <StaticResource ResourceKey="DataGridColumnHeaderStyle" />
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                    <Image Width="16" VerticalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Scan">
                                                        <Setter Property="Source" Value="{controlExtensions:ImageResource Source={x:Static resource:ResourceConstKeys.COMMON_THEME_PIC_WAIT_PNG}}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                                        <Setter Property="Source" Value="{controlExtensions:ImageResource Source={x:Static resource:ResourceConstKeys.COMMON_THEME_PIC_SUCCESS_PNG}}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancel">
                                                        <Setter Property="Source" Value="{controlExtensions:ImageResource Source={x:Static resource:ResourceConstKeys.COMMON_THEME_PIC_FAIL_PNG}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Margin="10,0"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Text="{Binding StatusDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Width="2.5*"
                                        Binding="{Binding Remarks}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="备注"
                                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}" />
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="50" />
                        <Setter Property="Height" Value="50" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Scan">
                                <Setter Property="Background" Value="#FFF3E0" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Cancel">
                                <Setter Property="Background" Value="#60FF0000" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="20,0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.CellStyle>
            </DataGrid>
        </Grid>
    </Grid>
</models:BaseRegionUserControl>
