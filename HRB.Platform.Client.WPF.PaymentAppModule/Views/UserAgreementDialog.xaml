<UserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Views.UserAgreementDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Core.ViewModels;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Core"
             xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             Width="800"
             Height="600"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <!--  按钮样式  -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="30,12" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Padding="30" Background="White" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题  -->
            <TextBlock Grid.Row="0"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#333333"
                       Text="{Binding Title}"
                       TextAlignment="Center" />

            <!--  协议内容（可滚动）  -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4">
                <markdig:MarkdownViewer Markdown="{Binding AgreementContent}"
                                        Padding="20"
                                         />
            </Border>

            <!--  提示文字  -->
            <TextBlock Grid.Row="3"
                       Margin="0,10,0,0"
                       FontSize="14"
                       Foreground="#DC3545"
                       Text="请仔细阅读以上条款，点击 同意 表示您已充分理解并接受所有条款。"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <!--  按钮  -->
            <StackPanel Grid.Row="4"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button Background="#4CAF50"
                        Command="{Binding AgreeCommand}"
                        Content="同意"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button Margin="20,0,0,0"
                        Background="#DC3545"
                        Command="{Binding DeclineCommand}"
                        Content="拒绝"
                        Style="{StaticResource DialogButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
