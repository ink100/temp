<models:BaseRegionUserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Views.SettingsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:models="clr-namespace:HRB.Platform.Client.WPF.Core.Models;assembly=HRB.Platform.Client.WPF.Core"
                              xmlns:converters="clr-namespace:HRB.Platform.Client.WPF.PaymentAppModule.Core.Converters;assembly=HRB.Platform.Client.WPF.PaymentAppModule.Core"
                              d:DesignHeight="1080"
                              d:DesignWidth="1920"
                              mc:Ignorable="d">
    <UserControl.Resources>
        <!--  转换器  -->
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!--  统一按钮样式  -->
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  激活状态指示器样式  -->
        <Style x:Key="ActivationStatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#DC3545" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActivated}" Value="True">
                    <Setter Property="Fill" Value="#4CAF50" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Grid Grid.Row="0" Background="#0078D7">
            <StackPanel Margin="20,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontSize="24"
                           Foreground="White"
                           Text="系统设置" />

                <TextBlock Margin="15,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#FFE082"
                           Text="{Binding PluginControlsDisabledHint}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPluginControlsEnabled}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Background="#28A745"
                        Command="{Binding GoBackCommand}"
                        Content="返回主页"
                        Style="{StaticResource ButtonStyle}" />
                <Button Margin="12,0,0,0"
                        Background="#DC3545"
                        Command="{Binding ExitCommand}"
                        Content="退出"
                        Style="{StaticResource ButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  主内容区域  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,40,40,40" HorizontalAlignment="Center">

                <!--  激活状态卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#333333"
                                       Text="激活状态" />
                            <Ellipse Width="16"
                                     Height="16"
                                     Margin="15,0,0,0"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ActivationStatusIndicatorStyle}" />
                        </StackPanel>

                        <!--  激活状态  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="当前状态：" />
                            <TextBlock Grid.Column="1"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#0078D7"
                                       Text="{Binding ActivationStatus}" />
                        </Grid>

                        <!--  到期时间  -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="到期时间：" />
                            <TextBlock Grid.Column="1"
                                       FontSize="16"
                                       Foreground="#333333"
                                       Text="{Binding ExpiresAt}" />
                        </Grid>

                        <!--  剩余天数  -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="剩余天数：" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#00A152"
                                           Text="{Binding RemainingDays}" />
                                <TextBlock Margin="5,0,0,0"
                                           FontSize="16"
                                           Foreground="#333333"
                                           Text="天" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!--  支付设置卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="支付方式设置" />

                        <TextBlock Grid.Row="0"
                                   Margin="180,4,0,0"
                                   VerticalAlignment="Top"
                                   FontSize="12"
                                   Foreground="#DC3545"
                                   Text="{Binding PluginControlsDisabledHint}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPluginControlsEnabled}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--  支付宝开关  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Text="支付宝" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="#999999"
                                           Text="启用后，可以接收支付宝支付信息" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsAlipayEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>

                        <!--  支付宝未支付昵称提醒播报开关  -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock FontSize="14"
                                           Foreground="#666666"
                                           Text="支付宝未支付昵称提醒播报" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="#999999"
                                           Text="启用后，播放未支付提示前会先播报用户昵称" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsAlipayNicknameReminderEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>

                        <!--  微信开关  -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Text="微信支付" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="#999999"
                                           Text="启用后，可以接收微信支付消息" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsWeChatEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>

                        <!--  微信未支付昵称提醒播报开关  -->
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock FontSize="14"
                                           Foreground="#666666"
                                           Text="微信未支付昵称提醒播报" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="#999999"
                                           Text="启用后,播放未支付提示前会先播报用户昵称" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsWeChatNicknameReminderEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>

                        <!--  开机自启动开关  -->
                        <Grid Grid.Row="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Text="开机自启动" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="#999999"
                                           Text="启用后,系统启动时自动运行收银台程序" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>

                        <!--  插件生命周期模式开关  -->
                        <Grid Grid.Row="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Text="插件生命周期模式" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="#999999"
                                           Text="启用后由看门狗管理消息中心/支付宝插件进程（建议切换后重启）" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding UseNewPluginLifecycleMode, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>
                    </Grid>
                </Border>

                <!--  店铺信息设置卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="店铺信息设置" />

                        <!--  店铺名称输入  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="店铺名称：" />

                            <TextBox Grid.Column="1"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsPluginControlsEnabled}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="BorderBrush" Value="#CCCCCC" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#0078D7" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!--  维护人员联系方式输入  -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="维护联系方式：" />

                            <TextBox Grid.Column="1"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding MaintenanceContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsPluginControlsEnabled}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="BorderBrush" Value="#CCCCCC" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#0078D7" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>

                <!--  消息通知设置卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="消息通知设置" />

                        <TextBlock Grid.Row="0"
                                   Margin="180,4,0,0"
                                   VerticalAlignment="Top"
                                   FontSize="12"
                                   Foreground="#DC3545"
                                   Text="{Binding PluginControlsDisabledHint}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPluginControlsEnabled}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--  通知接口URL输入  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="通知接口URL：" />

                            <TextBox Grid.Column="1"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding NotificationUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsPluginControlsEnabled}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="BorderBrush" Value="#CCCCCC" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#0078D7" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!--  启用通知开关  -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Text="启用消息通知" />
                                <TextBlock Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="#999999"
                                           Text="启用后，支付事件将推送到上方配置的接口地址（数据已脱敏）" />
                            </StackPanel>

                            <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding IsNotificationEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPluginControlsEnabled}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Width="60" Height="30">
                                                        <Border x:Name="SwitchBorder" Background="#CCCCCC" CornerRadius="15" />
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="24"
                                                                 Height="24"
                                                                 Margin="3,0,0,0"
                                                                 HorizontalAlignment="Left"
                                                                 Fill="White" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchBorder" Property="Background" Value="#4CAF50" />
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>
                    </Grid>
                </Border>

                <!--  机器序列号卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="机器序列号" />

                        <!--  序列号显示和复制  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="15"
                                    Background="White"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <TextBox FontFamily="Consolas"
                                         FontSize="16"
                                         Foreground="#333333"
                                         IsReadOnly="True"
                                         Text="{Binding MachineSN}"
                                         TextWrapping="Wrap" />
                            </Border>

                            <Button Grid.Column="1"
                                    Margin="15,0,0,0"
                                    Background="#4CAF50"
                                    Command="{Binding CopySNCommand}"
                                    Content="复制"
                                    Style="{StaticResource ButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <!--  激活操作卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="激活操作" />

                        <!--  选择激活文件按钮  -->
                        <Button Grid.Row="2"
                                Height="60"
                                Background="#0078D7"
                                Command="{Binding SelectKeyFileCommand}"
                                Content="选择激活文件 (.key)"
                                Style="{StaticResource ButtonStyle}" />

                        <!--  激活文件路径显示  -->
                        <Border Grid.Row="4"
                                Padding="15"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBlock FontFamily="Consolas"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Text="{Binding LicenseFilePath, FallbackValue='未选择激活文件'}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LicenseFilePath}" />
                        </Border>

                        <!--  激活按钮  -->
                        <Button Grid.Row="6"
                                Height="60"
                                Background="#4CAF50"
                                Command="{Binding ActivateCommand}"
                                IsEnabled="{Binding IsActivating, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource ButtonStyle}">
                            <Grid>
                                <TextBlock FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Text="激活软件"
                                           Visibility="{Binding IsActivating, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />
                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsActivating, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Text="激活中..." />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>


                <!--  语音与显示设置卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        MinWidth="900"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="语音与显示设置" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#333333" Text="扫码未支付通知" />
                                <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="#999999" Text="默认第 10 秒提醒一次并超时取消；语音重复播报间隔默认 1 秒。" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsScanNotPayVoiceEnabled, Mode=TwoWay}" />
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="125" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="扫码超时秒数：" />
                            <TextBox Grid.Column="1" Padding="8" FontSize="14" Text="{Binding ScanTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="未支付提醒间隔：" />
                            <TextBox Grid.Column="4" Padding="8" FontSize="14" Text="{Binding ScanNotPayNotifyIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="6" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="提醒次数：" />
                            <TextBox Grid.Column="7" Padding="8" FontSize="14" Text="{Binding ScanNotPayVoiceRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="9" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="播报间隔秒数：" />
                            <TextBox Grid.Column="10" Padding="8" FontSize="14" Text="{Binding VoiceRepeatIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center" FontSize="16" Content="播报上次未支付通知" IsChecked="{Binding IsPriorUnpaidVoiceEnabled, Mode=TwoWay}" />
                            <TextBox Grid.Column="1" Padding="8" FontSize="14" Text="{Binding PriorUnpaidVoiceRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="3" VerticalAlignment="Center" FontSize="16" Content="支付取消通知" IsChecked="{Binding IsPaymentCancelledVoiceEnabled, Mode=TwoWay}" />
                            <TextBox Grid.Column="4" Padding="8" FontSize="14" Text="{Binding PaymentCancelledVoiceRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center" FontSize="16" Content="支付成功金额播报" IsChecked="{Binding IsPaymentSuccessVoiceEnabled, Mode=TwoWay}" />
                            <Button Grid.Column="1" Background="#0078D7" Command="{Binding TestVoiceCommand}" Content="测试播放效果" Style="{StaticResource ButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="播报音色：" />
                            <ComboBox Grid.Column="1" Padding="8" FontSize="14" ItemsSource="{Binding TtsVoiceOptions}" SelectedItem="{Binding SelectedTtsVoiceName, Mode=TwoWay}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="语速：" />
                            <Slider Grid.Column="4" Minimum="-50" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="True" Value="{Binding TtsRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="14" Foreground="#666666" Text="{Binding TtsRate, StringFormat={}{0}%}" />
                        </Grid>

                        <Grid Grid.Row="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="音量：" />
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="True" Value="{Binding TtsVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="#666666" Text="{Binding TtsVolume, StringFormat={}{0}%}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="字体大小：" />
                            <TextBox Grid.Column="5" Padding="8" FontSize="14" Text="{Binding DisplayFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="7" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Text="金额颜色：" />
                            <TextBox Grid.Column="8" Padding="8" FontSize="14" Text="{Binding AmountColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Border Grid.Column="9" Width="40" Height="30" Margin="10,0" BorderBrush="#CCCCCC" BorderThickness="1" Background="{Binding AmountColorPreviewBrush}" />
                            <Button Grid.Column="10" Background="#6C757D" Command="{Binding ChooseAmountColorCommand}" Content="选择颜色" Style="{StaticResource ButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <!--  文档与版本信息卡片  -->
                <Border Margin="0,0,0,30"
                        Padding="30"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="15" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  标题  -->
                        <TextBlock Grid.Row="0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Text="文档与版本信息" />

                        <!--  知情同意书按钮  -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <!--<Sta.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="*" />
                            </Sta.ColumnDefinitions>-->
                            <Button 
                                    Height="50"
                                    MinWidth="200"
                                    Background="#FF9800"
                                    Command="{Binding ShowDisclaimerCommand}"
                                    Content="查看免责条款与知情同意书"
                                    Style="{StaticResource ButtonStyle}" />

                            <Button Margin="15,0"
                                    Height="50"
                                    MinWidth="200"
                                    Background="#2196F3"
                                    Command="{Binding ShowNotificationConsentCommand}"
                                    Content="查看支付消息通知服务知情同意书"
                                    Style="{StaticResource ButtonStyle}" />
                        </StackPanel>

                        <!--  版本信息  -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Text="软件版本号：" />
                            <TextBlock Grid.Column="1"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#0078D7"
                                       Text="{Binding AppVersion}" />
                        </Grid>

                        <!--  说明文本  -->
                        <TextBlock Grid.Row="6"
                                   FontSize="12"
                                   Foreground="#999999"
                                   Text="点击上方按钮可查看相关法律文档和条款" />
                    </Grid>
                </Border>

                <!--  使用说明  -->
                <Border Padding="30"
                        Background="#FFF9E6"
                        BorderBrush="#FFE082"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F57C00"
                                   Text="使用说明" />
                        <TextBlock Margin="0,15,0,0"
                                   FontSize="14"
                                   Foreground="#666666"
                                   LineHeight="24"
                                   TextWrapping="Wrap">
                            <Run Text="1. 复制上方的序列号" />
                            <LineBreak />
                            <Run Text="2. 将序列号提供给管理员，获取激活文件（.key）" />
                            <LineBreak />
                            <Run Text="3. 点击[选择激活文]件按钮，选择获取的 .key 文件" />
                            <LineBreak />
                            <Run Text="4. 点击[激活软件]按钮完成激活" />
                            <LineBreak />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="#DC3545" Text="注意：激活需要网络连接以验证时间，请确保网络畅通" />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</models:BaseRegionUserControl>
