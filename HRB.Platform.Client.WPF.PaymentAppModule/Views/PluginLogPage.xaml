<models:BaseRegionUserControl x:Class="HRB.Platform.Client.WPF.PaymentAppModule.Views.PluginLogPage"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:models="clr-namespace:HRB.Platform.Client.WPF.Core.Models;assembly=HRB.Platform.Client.WPF.Core"
                             xmlns:prism="http://prismlibrary.com/"
                             d:DesignHeight="800"
                             d:DesignWidth="1200"
                             prism:ViewModelLocator.AutoWireViewModel="True"
                             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DataGridTextColumnStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="DataGridSuccessStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridTextColumnStyle}">
            <Setter Property="Foreground" Value="#00A152" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="DataGridErrorStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridTextColumnStyle}">
            <Setter Property="Foreground" Value="#D32F2F" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Grid Grid.Row="0" Background="#0078D7">
            <TextBlock Margin="20,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="24"
                       Foreground="White"
                       Text="插件运行日志" />

            <StackPanel Margin="0,0,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Margin="0,0,10,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateToMainCommand}"
                        Cursor="Hand">
                    <Border Width="60"
                            Height="35"
                            Background="#E0E0E0"
                            CornerRadius="4">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="Black"
                                   Text="返回" />
                    </Border>
                </Button>
                <Button Margin="0,0,0,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding RefreshCommand}"
                        Cursor="Hand">
                    <Border Width="60"
                            Height="35"
                            Background="#E0E0E0"
                            CornerRadius="4">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="Black"
                                   Text="刷新" />
                    </Border>
                </Button>
            </StackPanel>
        </Grid>

        <!--  筛选条件区域  -->
        <Border Grid.Row="1"
                Margin="20,15"
                Padding="20,15"
                Background="#F5F5F5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Text="插件筛选：" />
                <ComboBox Grid.Column="1"
                          FontSize="14"
                          ItemsSource="{Binding PluginFilterOptions}"
                          SelectedItem="{Binding SelectedPluginFilter}" />
                <TextBlock Grid.Column="2"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="#666666"
                           Text="{Binding PageInfo}" />
            </Grid>
        </Border>

        <!--  数据表格  -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <DataGrid AlternatingRowBackground="#FAFAFA"
                      AutoGenerateColumns="False"
                      Background="White"
                      BorderThickness="0"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="False"
                      CanUserSortColumns="False"
                      ColumnHeaderHeight="50"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#E0E0E0"
                      IsReadOnly="True"
                      ItemsSource="{Binding Logs}"
                      RowBackground="White"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      VerticalGridLinesBrush="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="1.5*"
                                        Binding="{Binding CreateDateTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="时间">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#333333" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="Padding" Value="15,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="50" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="1.2*"
                                        Binding="{Binding PluginName}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="插件名称">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#333333" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="Padding" Value="15,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="50" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="0.8*"
                                        Binding="{Binding OperationType}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="操作类型">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#333333" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="Padding" Value="15,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="50" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="0.6*" Header="状态">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#333333" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="Padding" Value="15,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="50" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextColumnStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                    <Setter Property="Text" Value="成功" />
                                                    <Setter Property="Foreground" Value="#00A152" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                    <Setter Property="Text" Value="失败" />
                                                    <Setter Property="Foreground" Value="#D32F2F" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="2.5*"
                                        Binding="{Binding Message}"
                                        ElementStyle="{StaticResource DataGridTextColumnStyle}"
                                        Header="消息">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#333333" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="Padding" Value="15,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="50" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="45" />
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="15,8" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                </DataGrid.CellStyle>
            </DataGrid>
        </Grid>

        <!--  分页控制栏  -->
        <Border Grid.Row="3"
                Margin="20,0,20,20"
                Padding="20,15"
                Background="#F5F5F5">
            <StackPanel HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button Width="80"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#0078D7"
                        Command="{Binding FirstPageCommand}"
                        Content="首页"
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="White" />
                <Button Width="80"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#0078D7"
                        Command="{Binding PreviousPageCommand}"
                        Content="上一页"
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="White" />
                <TextBlock Margin="20,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="#333333"
                           Text="{Binding PageInfo}" />
                <Button Width="80"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#0078D7"
                        Command="{Binding NextPageCommand}"
                        Content="下一页"
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="White" />
                <Button Width="80"
                        Height="35"
                        Background="#0078D7"
                        Command="{Binding LastPageCommand}"
                        Content="末页"
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="White" />
            </StackPanel>
        </Border>
    </Grid>
</models:BaseRegionUserControl>
